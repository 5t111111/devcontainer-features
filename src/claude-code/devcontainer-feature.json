{
    "id": "claude-code",
    "version": "0.2.2",
    "name": "Claude Code",
    "documentationURL": "https://github.com/5t111111/devcontainer-features/tree/main/src/claude-code",
    "description": "Installs the latest native version of Claude Code CLI with enhanced security measures including checksum verification.",
    "options": {
        "version": {
            "type": "string",
            "enum": [
                "latest",
                "stable"
            ],
            "default": "latest",
            "description": "Version channel to install (latest or stable)"
        },
        "persistAuth": {
            "type": "boolean",
            "default": true,
            "description": "Persist Claude Code authentication using named volume. Set to false to disable persistence for security-sensitive environments."
        }
    },
    "mounts": [
        {
            "type": "volume",
            "source": "claude-config-${devcontainerId}",
            "target": "/var/lib/claude-config"
        },
        {
            "type": "volume",
            "source": "claude-config-xdg-${devcontainerId}",
            "target": "/var/lib/claude-config-xdg"
        }
    ],
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ]
}
